data/*
!data/.gitkeep

# ============================
# 管理画面の認証情報（将来的に追加する場合）
# ============================
admin/.htpasswd
admin/.env

# ============================
# OS・エディタ生成ファイル
# ============================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# ログ・一時ファイル
# ============================
*.log
/tmp/

# ============================
# コンテンツ（容量が大きいため除外）
# ============================
images/
